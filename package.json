{
  "name": "vue-table-suggest",
  "private": false,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/lib/index.cjs",
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.cjs"
    },
    "./style.css": "./dist/lib/vue-table-suggest.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/lib"
  ],
  "scripts": {
    "build": "vue-tsc -b && vite build && vite build -c vite.lib.config.ts && vue-tsc -p tsconfig.lib.json && vite build -c vite.codepen.config.ts",
    "test": "npm run build && vue-tsc --noEmit -p tsconfig.app.json && eslint src tests --ext .ts,.vue && vitest run --coverage && playwright test",
    "watch": "vite"
  },
  "peerDependencies": {
    "quasar": "^2.18.5",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@quasar/extras": "^1.17.0",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.3",
    "eslint-plugin-vue": "^10.8.0",
    "jsdom": "^27.0.1",
    "prettier": "^3.8.1",
    "quasar": "^2.18.5",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "vue": "^3.5.25",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.1.5"
  }
}
